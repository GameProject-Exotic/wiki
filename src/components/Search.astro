---
import './styles/search.css'
---

<div class='search'>
  <button class='search-button' aria-label='Поиск'>
    <svg
      role='img'
      xmlns='http://www.w3.org/2000/svg'
      viewBox='0 0 24 24'
      fill='currentColor'
      aria-hidden='true'
    >
      <title>搜索</title>
      <g fill='none' fill-rule='evenodd'>
        <path
          d='m12.593 23.258l-.011.002l-.071.035l-.02.004l-.014-.004l-.071-.035q-.016-.005-.024.005l-.004.01l-.017.428l.005.02l.01.013l.104.074l.015.004l.012-.004l.104-.074l.012-.016l.004-.017l-.017-.427q-.004-.016-.017-.018m.265-.113l-.013.002l-.185.093l-.01.01l-.003.011l.018.43l.005.012l.008.007l.201.093q.019.005.029-.008l.004-.014l-.034-.614q-.005-.018-.02-.022m-.715.002a.02.02 0 0 0-.027.006l-.006.014l-.034.614q.001.018.017.024l.015-.002l.201-.093l.01-.008l.004-.011l.017-.43l-.003-.012l-.01-.01z'
        ></path>
        <path
          fill='currentColor'
          d='M5 10a5 5 0 1 1 10 0a5 5 0 0 1-10 0m5-7a7 7 0 1 0 4.192 12.606l5.1 5.101a1 1 0 0 0 1.415-1.414l-5.1-5.1A7 7 0 0 0 10 3'
        ></path>
      </g>
    </svg>
  </button>
  <div class='search-container' style='visibility: hidden; opacity: 0; pointer-events: none;'>
    <div class='search-space'>
      <input
        autocomplete='off'
        class='search-bar'
        name='search'
        type='text'
        aria-label='Поиск'
        placeholder='Название статьи для поиска...'
      />
      <div class='search-filters'>
        <div class='filter-group'>
          <label class='filter-label'>Период</label>
          <select class='filter-select' data-filter='date'>
            <option value='all'>Всё время</option>
            <option value='year'>Этот год</option>
            <option value='6months'>Эти 6 месяцев</option>
            <option value='3months'>Эти 3 месяца</option>
            <option value='month'>Этот месяц</option>
          </select>
        </div>
        <div class='filter-group'>
          <label class='filter-label'>Метки</label>
          <div class='filter-multiselect' data-filter='tags'>
            <button class='filter-multiselect-button' type='button' aria-label='Выберите'>
              <span class='filter-multiselect-text'>Все</span>
              <span class='filter-multiselect-arrow'>▼</span>
            </button>
            <div class='filter-multiselect-dropdown'>
              <!-- 选项将由 JavaScript 动态生成 -->
            </div>
          </div>
        </div>
        <div class='filter-group'>
          <label class='filter-label'>Тип</label>
          <div class='filter-multiselect' data-filter='type'>
            <button class='filter-multiselect-button' type='button' aria-label='Выберите'>
              <span class='filter-multiselect-text'>Все</span>
              <span class='filter-multiselect-arrow'>▼</span>
            </button>
            <div class='filter-multiselect-dropdown'>
              <div class='filter-multiselect-option'>
                <input type='checkbox' id='type-all' value='all' checked />
                <label for='type-all'>Все</label>
              </div>
              <div class='filter-multiselect-option'>
                <input type='checkbox' id='type-blog' value='blog' />
                <label for='type-blog'>Статья</label>
              </div>
              <div class='filter-multiselect-option'>
                <input type='checkbox' id='type-docs' value='docs' />
                <label for='type-docs'>Документ</label>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class='search-layout' data-preview='true'></div>
    </div>
  </div>
</div>

<script>
  import('./scripts/search.ts')
</script>
